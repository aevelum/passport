{
  "artifact": "passport_hardening_architecture_rules",
  "schemaVersion": "0.1.0",
  "rules": [
    {
      "id": "arch.agent.repo-local-skill-discovery",
      "severity": "high",
      "description": "Repo hardening skills must live in Codex's repo skill discovery path.",
      "type": "required-paths",
      "paths": [
        "AGENTS.md",
        ".agents/skills/passport-hardening-loop/SKILL.md",
        ".agents/skills/passport-hardening-loop/agents/openai.yaml",
        ".agents/skills/passport-ui-design-system/SKILL.md",
        ".agents/skills/passport-ui-design-system/agents/openai.yaml",
        ".github/workflows/ci.yml",
        "package.json",
        "package-lock.json",
        "scripts/generated-time.mjs",
        "interop/core/readiness.js",
        "interop/plugins/cdm/readiness.js",
        "docs/09_adapter_readiness_levels.md",
        "hardening/rounds/round-0002.md",
        "hardening/rounds/round-0003.md",
        "hardening/rounds/round-0004.md",
        "hardening/rounds/round-0005.md"
      ]
    },
    {
      "id": "arch.agent.agents-md-points-to-skill",
      "severity": "high",
      "description": "Root AGENTS.md must tell future agents to use the repo-local hardening skill.",
      "type": "required-substrings",
      "files": [
        "AGENTS.md"
      ],
      "contains": [
        ".agents/skills/passport-hardening-loop/SKILL.md",
        ".agents/skills/passport-ui-design-system/SKILL.md",
        "npm run hardening:gate",
        "design/tokens/colors.json",
        "Adapter behavior, adapter docs, interop reports, framework claims, partner/sandbox/production language, or readiness level changes are hardening-sensitive.",
        "Default PR CI should use standard GitHub-hosted runners with explicit Node, Java, DPM, and npm setup. Repo-authored validation and generation paths must not fetch schemas, plugin code, or mutable runtime inputs except through explicit vendoring commands."
      ]
    },
    {
      "id": "arch.interop.adapter-readiness-model",
      "severity": "high",
      "description": "Adapter readiness levels must be machine-readable and evidence-gated.",
      "type": "required-substrings",
      "files": [
        "interop/core/readiness.js"
      ],
      "contains": [
        "ADAPTER_READINESS_LEVELS",
        "assertReadinessShape",
        "readinessSummary",
        "assertReadinessEvidenceBound",
        "assertReadinessEvidenceReferences",
        "Artifact Conformance"
      ]
    },
    {
      "id": "arch.interop.adapter-contract-readiness",
      "severity": "high",
      "description": "The adapter contract must reject plugins without readiness metadata.",
      "type": "required-substrings",
      "files": [
        "interop/core/adapter.js"
      ],
      "contains": [
        "readiness",
        "assertReadinessShape",
        "assertReadinessEvidenceBound",
        "registered adapters must be Level 1-5"
      ]
    },
    {
      "id": "arch.interop.cdm-readiness-level-2",
      "severity": "high",
      "description": "The current CDM adapter must remain Level 2 until higher-level evidence exists.",
      "type": "required-substrings",
      "files": [
        "interop/plugins/cdm/readiness.js"
      ],
      "contains": [
        "level: 2",
        "Artifact Conformance",
        "FINOS certification",
        "Rosetta Engine execution",
        "Canton Token Standard integration"
      ]
    },
    {
      "id": "arch.interop.registry-readiness",
      "severity": "high",
      "description": "The static registry must publish adapter readiness metadata.",
      "type": "required-substrings",
      "files": [
        "interop/registry.js"
      ],
      "contains": [
        "readinessSummary"
      ]
    },
    {
      "id": "arch.interop.report-readiness",
      "severity": "high",
      "description": "Interop reports must publish adapter readiness outside generated payloads.",
      "type": "required-substrings",
      "files": [
        "interop/runner.js"
      ],
      "contains": [
        "adapterReadiness"
      ]
    },
    {
      "id": "arch.interop.static-registry",
      "severity": "critical",
      "description": "The interop registry must remain static and frozen.",
      "type": "required-substrings",
      "files": [
        "interop/registry.js"
      ],
      "contains": [
        "import { cdmPlugin } from './plugins/cdm/index.js';",
        "export const adapterRegistry = Object.freeze([",
        "cdmPlugin"
      ]
    },
    {
      "id": "arch.interop.no-dynamic-execution",
      "severity": "critical",
      "description": "Repo-authored interop code must not dynamically load plugins or execute generated code.",
      "type": "forbidden-patterns",
      "paths": [
        "interop"
      ],
      "extensions": [
        ".js",
        ".mjs"
      ],
      "forbidden": [
        "import(",
        "eval(",
        "new Function",
        "require-from-string",
        "node:vm",
        "vm."
      ]
    },
    {
      "id": "arch.ci.network-only-explicit-vendor",
      "severity": "critical",
      "description": "Network fetches must stay isolated to the explicit CDM vendor module.",
      "type": "allow-pattern-only",
      "paths": [
        "interop",
        "scripts",
        "hardening/scripts"
      ],
      "extensions": [
        ".js",
        ".mjs",
        ".sh"
      ],
      "pattern": "fetch(",
      "allowed_files": [
        "interop/plugins/cdm/vendor.js"
      ]
    },
    {
      "id": "arch.ci.no-vendor-refresh-in-default-ci",
      "severity": "critical",
      "description": "Default CI must not refresh vendored schemas from the network.",
      "type": "forbidden-patterns",
      "files": [
        "scripts/ci.sh",
        ".github/workflows/ci.yml"
      ],
      "forbidden": [
        "interop:vendor:cdm",
        "cdm:vendor"
      ]
    },
    {
      "id": "arch.ci.github-workflow-hosted",
      "severity": "critical",
      "description": "The default PR workflow must use a standard GitHub-hosted runner with explicit toolchain setup and lockfile dependency installation.",
      "type": "required-substrings",
      "files": [
        ".github/workflows/ci.yml"
      ],
      "contains": [
        "permissions:",
        "contents: read",
        "runs-on: ubuntu-latest",
        "actions/checkout@v6",
        "actions/setup-node@v6",
        "node-version: 24",
        "actions/setup-java@v5",
        "java-version: \"17\"",
        "actions/cache@v5",
        "dpm-${{ runner.os }}-3.5.1-rc3",
        "fetch-depth: 1",
        "persist-credentials: false",
        "curl -fsSL https://get.digitalasset.com/install/install.sh -o /tmp/install-dpm.sh",
        "dpm install 3.5.1-rc3",
        "dpm version --active",
        "npm ci --ignore-scripts --audit=false --fund=false",
        "npm run ci"
      ]
    },
    {
      "id": "arch.ci.hardening-gate-in-ci",
      "severity": "high",
      "description": "The hardening gate, package step, and freshness diff must run in default local CI.",
      "type": "required-substrings",
      "files": [
        "scripts/ci.sh"
      ],
      "contains": [
        "npm run hardening:map",
        "npm run hardening:frontier",
        "npm run hardening:gate",
        "npm run package",
        "git diff --exit-code -- artifacts hardening/frontiers hardening/maps"
      ]
    },
    {
      "id": "arch.ci.deterministic-generated-time",
      "severity": "high",
      "description": "Generated tracked reports must use the shared deterministic timestamp helper.",
      "type": "required-substrings",
      "files": [
        "scripts/generated-time.mjs",
        "interop/context.js",
        "scripts/gates.mjs",
        "hardening/scripts/hardening-gate.mjs"
      ],
      "contains": [
        "getGeneratedAt"
      ]
    },
    {
      "id": "arch.no-global-cdm-special-case",
      "severity": "high",
      "description": "CDM schemas and fixtures must stay plugin-scoped.",
      "type": "absent-paths",
      "paths": [
        "schemas/cdm",
        "fixtures/cdm",
        "scripts/validate-cdm-conformance.mjs",
        "scripts/vendor-cdm-schemas.mjs",
        "artifacts/cdm_conformance_report.json"
      ]
    },
    {
      "id": "arch.scope.canonical-docs",
      "severity": "critical",
      "description": "README and release scope docs must preserve the precise Passport public-core boundary.",
      "type": "required-substrings",
      "files": [
        "README.md",
        "docs/02_foundation_release_scope.md"
      ],
      "contains": [
        "Aevelum Passport is the public Canton/Daml foundation for private collateral-readiness credentials.",
        "Passport records readiness.",
        "Passport may record a reservation handoff notice.",
        "Passport does not execute the downstream trade.",
        "Passport does not custody, transfer, settle, or move collateral.",
        "CapacityReservation is visible to holder, attester, and verifier.",
        "ReservationHandoffInstruction is visible to the handoff recipient.",
        "AuditDisclosureGrant is visible to the auditor."
      ]
    },
    {
      "id": "arch.scope.reservation-handoff-daml",
      "severity": "critical",
      "description": "Passport-owned Daml must use non-executing reservation handoff terminology.",
      "type": "required-substrings",
      "files": [
        "packages/passport-core/daml/Aevelum/Passport/Foundation.daml"
      ],
      "contains": [
        "ReservationHandoffInstruction",
        "CreateReservationHandoff",
        "handoffRecipient"
      ]
    },
    {
      "id": "arch.scope.no-out-of-scope-daml-language",
      "severity": "critical",
      "description": "Passport-owned Daml must not introduce execution, custody, settlement, wallet, optimizer, credit-decision, or proof-system implementation terms.",
      "type": "forbidden-patterns",
      "paths": [
        "packages/passport-core/daml",
        "packages/passport-tests/daml"
      ],
      "extensions": [
        ".daml"
      ],
      "forbidden": [
        "ExecutionInstruction",
        "ConvertToExecutionInstruction",
        "executionRailParty",
        "handoffObserver",
        "ReservationHandedOff",
        "auditor : Optional Party",
        "SettlementFinality",
        "CustodyWallet",
        "CollateralOptimizer",
        "CreditApproval",
        "CreditDecision",
        "ZKProof",
        "ZeroKnowledge"
      ]
    },
    {
      "id": "arch.release.package-tracked-files",
      "severity": "medium",
      "description": "Release packaging must use git-tracked files as its input set.",
      "type": "required-substrings",
      "files": [
        "scripts/package.mjs"
      ],
      "contains": [
        "git",
        "ls-files"
      ]
    }
  ]
}
