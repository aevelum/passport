module Aevelum.Passport.Test.ReservationTests where

import Daml.Script
import Aevelum.Passport.Types
import Aevelum.Passport.Foundation
import Aevelum.Passport.Test.FoundationScenario

t006_reserve_partial_capacity : Script ()
t006_reserve_partial_capacity = script do
  reserved <- createReservedContext
  dealerReservations <- query @CapacityReservation reserved.presented.base.actors.dealer
  holderCredentials <- query @CapacityCredential reserved.presented.base.actors.holder
  assertMsg "dealer should see one active reservation" (length dealerReservations == 1)
  assertMsg "holder should see residual credential after partial reservation" (length holderCredentials >= 1)
  return ()

t007_reject_over_reservation : Script ()
t007_reject_over_reservation = script do
  presented <- createPresentedContext
  let holder = presented.base.actors.holder
  let dealer = presented.base.actors.dealer
  let attester = presented.base.actors.attester
  setTime reservationLedgerTime
  submitMustFail (actAs holder <> actAs attester <> actAs dealer) do
    exerciseCmd presented.presentationCid ReserveFromPresentation with
      reservationId = "reservation-over-001"
      reservedAmount = 60000000.0
      reservationPurpose = RepoPreTradeReservation
      reservationValidUntil = "2026-05-10T04:03:00Z"
      reservationValidUntilTime = demoReservationValidUntilTime
      residualCredentialId = "credential-residual-over-001"
  dealerReservations <- query @CapacityReservation dealer
  assertMsg "over reservation should not create a reservation" (length dealerReservations == 0)
  return ()

t008_consume_and_reissue_residual_capacity : Script ()
t008_consume_and_reissue_residual_capacity = script do
  reserved <- createReservedContext
  holderCredentials <- query @CapacityCredential reserved.presented.base.actors.holder
  dealerCredentials <- query @CapacityCredential reserved.presented.base.actors.dealer
  assertMsg "holder should retain residual capacity credential" (length holderCredentials >= 1)
  assertMsg "dealer should not see raw residual credential" (length dealerCredentials == 0)
  return ()

t009_release_reservation : Script ()
t009_release_reservation = script do
  reserved <- createReservedContext
  let holder = reserved.presented.base.actors.holder
  let dealer = reserved.presented.base.actors.dealer
  let attester = reserved.presented.base.actors.attester
  setTime releaseLedgerTime
  _releasedCredentialCid <- submit (actAs holder <> actAs attester <> actAs dealer) do
    exerciseCmd reserved.reservationCid ReleaseReservation with
      releasedCredentialId = "credential-released-009"
      releasedAt = "2026-05-10T01:00:00Z"
  dealerReservations <- query @CapacityReservation dealer
  assertMsg "release consumes reservation" (length dealerReservations == 0)
  return ()

t019_expire_reservation : Script ()
t019_expire_reservation = script do
  reserved <- createReservedContext
  let holder = reserved.presented.base.actors.holder
  let dealer = reserved.presented.base.actors.dealer
  let attester = reserved.presented.base.actors.attester
  setTime reservationExpiredLedgerTime
  _revocationCid <- submit (actAs holder <> actAs attester <> actAs dealer) do
    exerciseCmd reserved.reservationCid ExpireReservation with
      revocationId = "reservation-expiration-001"
      expiredAt = "2026-05-10T05:00:00Z"
  dealerRevocations <- query @CredentialRevocation dealer
  dealerReservations <- query @CapacityReservation dealer
  assertMsg "expiring reservation should create a revocation notice" (length dealerRevocations == 1)
  assertMsg "expiring reservation consumes active reservation" (length dealerReservations == 0)
  return ()

t020_create_reservation_handoff : Script ()
t020_create_reservation_handoff = script do
  reserved <- createReservedContext
  let holder = reserved.presented.base.actors.holder
  let dealer = reserved.presented.base.actors.dealer
  let attester = reserved.presented.base.actors.attester
  let recipient = reserved.presented.base.actors.operator
  let auditor = reserved.presented.base.actors.auditor
  setTime releaseLedgerTime
  _handoffCid <- submit (actAs holder <> actAs attester <> actAs dealer) do
    exerciseCmd reserved.reservationCid CreateReservationHandoff with
      handoffId = "reservation-handoff-001"
      handoffRecipient = recipient
      handoffPurpose = "repo pre-trade readiness handoff"
      handoffCreatedAt = "2026-05-10T01:15:00Z"
  recipientHandoffs <- query @ReservationHandoffInstruction recipient
  dealerReservations <- query @CapacityReservation dealer
  recipientReservations <- query @CapacityReservation recipient
  auditorReservations <- query @CapacityReservation auditor
  assertMsg "handoff recipient should see reservation handoff instruction" (length recipientHandoffs == 1)
  assertMsg "handoff is nonconsuming and keeps reservation active" (length dealerReservations == 1)
  case dealerReservations of
    [(_, reservation)] -> assertMsg "handoff does not mutate reservation status" (reservation.status == ReservationActive)
    _ -> assertMsg "dealer should see exactly one reservation after handoff" False
  assertMsg "handoff recipient should not see reservation through reservation-level observer" (length recipientReservations == 0)
  assertMsg "auditor should not see reservation through reservation-level observer" (length auditorReservations == 0)
  return ()

t021_dispute_reservation : Script ()
t021_dispute_reservation = script do
  reserved <- createReservedContext
  let holder = reserved.presented.base.actors.holder
  let dealer = reserved.presented.base.actors.dealer
  let attester = reserved.presented.base.actors.attester
  setTime releaseLedgerTime
  _disputeCid <- submit (actAs holder <> actAs attester <> actAs dealer) do
    exerciseCmd reserved.reservationCid DisputeReservation with
      disputeId = "reservation-dispute-001"
      disputedBy = dealer
      disputeReason = "dealer review requested"
      disputedAt = "2026-05-10T05:30:00Z"
  dealerDisputes <- query @ReservationDispute dealer
  holderDisputes <- query @ReservationDispute holder
  assertMsg "dealer should see reservation dispute" (length dealerDisputes == 1)
  assertMsg "holder should see reservation dispute" (length holderDisputes == 1)
  return ()

t023_release_preserves_policy_publisher : Script ()
t023_release_preserves_policy_publisher = script do
  actors <- mkActors
  let holder = actors.holder
  let verifier = actors.dealer
  let attester = actors.attester
  let policyPublisher = actors.operator

  accountCid <- submit holder do
    createCmd PassportAccount with
      accountId = "acct-policy-publisher-release-001"
      holder
      operator = Some policyPublisher
      displayName = "Policy Publisher Preservation Account"
      schemaVersion = "foundation-0.2"
      createdAt = "2026-05-10T00:00:00Z"
      status = AccountActive

  _policyCid <- submit policyPublisher do
    createCmd CollateralPolicy with
      policyId = "repo-policy-separate-publisher-001"
      policyVersion = "v1"
      policyPublisher
      approvedHolders = [holder]
      approvedAttesters = [attester]
      eligibleAssetClasses = [USTreasury]
      eligibleCurrencies = ["USD"]
      minimumCapacity = 40000000.0
      haircutScheduleRef = "haircut-separate-publisher-v1"
      concentrationLimitRef = "concentration-separate-publisher-v1"
      freshnessWindowHours = 24
      reservationAllowed = True
      validFrom = "2026-05-10T00:00:00Z"
      validFromTime = policyValidFromTime
      validUntil = "2026-05-12T00:00:00Z"
      validUntilTime = policyValidUntilTime
      schemaVersion = "foundation-0.2"
      status = PolicyActive

  setTime requestLedgerTime
  requestCid <- submit holder do
    exerciseCmd accountCid RequestCapacityCredential with
      requestId = "request-separate-publisher-001"
      policyId = "repo-policy-separate-publisher-001"
      policyVersion = "v1"
      policyPublisher
      attester
      requestedMinimumCapacity = 40000000.0
      capacityCurrency = "USD"
      purpose = RepoPreTrade
      requestedAt = "2026-05-10T00:01:00Z"

  setTime credentialValuationLedgerTime
  credentialCid <- submit (actAs holder <> actAs attester) do
    exerciseCmd requestCid IssueCapacityCredential with
      credentialId = "credential-separate-publisher-001"
      capacityAmount = 40000000.0
      capacityBand = AtLeast 40000000.0
      haircutScheduleRef = "haircut-separate-publisher-v1"
      valuationTimestamp = "2026-05-10T00:02:00Z"
      valuationTime = credentialValuationLedgerTime
      validFrom = "2026-05-10T00:02:00Z"
      validFromTime = credentialValuationLedgerTime
      validUntil = "2026-05-12T00:02:00Z"
      validUntilTime = demoCredentialValidUntilTime
      freshnessWindowHours = 24
      evidenceManifestHash = "sha256:evidence-separate-publisher-001"
      calculationMethodHash = "sha256:calculation-separate-publisher-001"
      reservableAmount = 40000000.0
      schemaVersion = "foundation-0.2"

  setTime presentationLedgerTime
  presentationCid <- submit holder do
    exerciseCmd credentialCid PresentToVerifier with
      presentationId = "presentation-separate-publisher-001"
      verifier
      presentationPurpose = RepoPreTrade
      presentedAt = "2026-05-10T00:03:00Z"

  setTime reservationLedgerTime
  outcome <- submit (actAs holder <> actAs attester <> actAs verifier) do
    exerciseCmd presentationCid ReserveFromPresentation with
      reservationId = "reservation-separate-publisher-001"
      reservedAmount = 20000000.0
      reservationPurpose = RepoPreTradeReservation
      reservationValidUntil = "2026-05-10T04:03:00Z"
      reservationValidUntilTime = demoReservationValidUntilTime
      residualCredentialId = "credential-residual-separate-publisher-001"

  setTime releaseLedgerTime
  _releasedCredentialCid <- submit (actAs holder <> actAs attester <> actAs verifier) do
    exerciseCmd outcome.reservationCid ReleaseReservation with
      releasedCredentialId = "credential-released-separate-publisher-001"
      releasedAt = "2026-05-10T01:00:00Z"

  holderCredentials <- query @CapacityCredential holder
  let releasedCredentials = filter (\(_, credential) -> credential.credentialId == "credential-released-separate-publisher-001") holderCredentials
  case releasedCredentials of
    [(_, credential)] -> do
      assertMsg "test setup keeps policy publisher distinct from verifier" (policyPublisher /= verifier)
      assertMsg "released credential should preserve original policy publisher" (credential.policyPublisher == policyPublisher)
    _ -> assertMsg "holder should see exactly one released credential" False
  return ()
